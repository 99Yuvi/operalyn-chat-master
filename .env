# # Node.js Chat Server — copy to .env and fill in values

# PORT=3001

# # Laravel API base URL (no trailing slash)
# LARAVEL_API_URL=http://localhost:8000/api/v1

# # Service token — generate in Laravel:
# #   php artisan tinker
# #   \App\Models\User::find(1)->createToken('node-service')->plainTextToken
# NODE_SERVICE_TOKEN=hKcq1Z5s6xXzBuRLveTnYQm9CjbEWp3U4iwHyFdO

# # Allowed CORS origin (React dev server or production domain)
# CORS_ORIGIN=http://localhost:5173
# Node.js Chat Server — copy to .env and fill in values

PORT=3001

# Laravel API base URL (no trailing slash)
LARAVEL_API_URL=https://api.operalyn.com/api/v1

# Service token — generate in Laravel:
#   php artisan tinker
#   \App\Models\User::find(1)->createToken('node-service')->plainTextToken
NODE_SERVICE_TOKEN=236|65I0Xiw5GfBb2B4YIlLRg897ZfjC3Gzt9hQh4BBO20450b78

# Allowed CORS origins — comma-separated (production + local dev)
CORS_ORIGIN=https://operalyn.com,http://localhost:5173,http://localhost:5174
